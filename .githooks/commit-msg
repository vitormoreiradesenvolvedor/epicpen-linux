#!/usr/bin/env bash
# Valida o formato da mensagem de commit (Conventional Commits).

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Ignora commits de merge e amend automáticos
echo "$COMMIT_MSG" | grep -qE "^Merge " && exit 0
echo "$COMMIT_MSG" | grep -qE "^Revert " && exit 0

PATTERN="^(feat|fix|chore|refactor|test|docs|style|perf|ci|build|revert)(\(.+\))?: .{1,72}"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
    echo ""
    echo "╔══════════════════════════════════════════════════════════╗"
    echo "║  COMMIT INVÁLIDO — formato de mensagem incorreto         ║"
    echo "║                                                          ║"
    echo "║  Use Conventional Commits:                               ║"
    echo "║    tipo(escopo): descrição                               ║"
    echo "║                                                          ║"
    echo "║  Tipos válidos:                                          ║"
    echo "║    feat, fix, chore, refactor, test, docs,               ║"
    echo "║    style, perf, ci, build, revert                        ║"
    echo "║                                                          ║"
    echo "║  Exemplos:                                               ║"
    echo "║    feat(overlay): add transparent drawing layer          ║"
    echo "║    fix(toolbar): correct color picker alignment          ║"
    echo "║    chore(build): update appimage build script            ║"
    echo "╚══════════════════════════════════════════════════════════╝"
    echo ""
    exit 1
fi
